# ── Backend Configuration (Go) ──────────────────────────────────────────────

# HTTP Server Port
PORT=8080

# (Optional) Event streaming and caching infra.
# If these are missing, the server falls back to running without them.
# KAFKA_BROKERS="localhost:9092"
# REDIS_URL="redis://localhost:6379"

# Supabase Auth: Modern Asymmetric Validation (Recommended)
# Found in Supabase Dashboard -> Settings -> API -> JWT Keys (Discovery URL)
SUPABASE_JWKS_URL="https://bgnlhbsckjpwmckrswas.supabase.co/auth/v1/.well-known/jwks.json"

# Supabase Auth: Legacy Symmetric Validation (Fallback)
# Used only if SUPABASE_JWKS_URL is empty. Found below Asymmetric keys.
# SUPABASE_JWT_SECRET="your-jwt-secret-here"


